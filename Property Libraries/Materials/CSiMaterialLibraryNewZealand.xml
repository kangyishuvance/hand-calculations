  <control lengthUnits="m" forceUnits="kN">
    <fileID>CSI Material Library for New Zealand</fileID>
    <fileVersion>2.2</fileVersion>
    <fileDescription>Built-in Material Property templates for New Zealand</fileDescription>
    <!-- 
	Version 2.0 
		steel materials rationalised
		steel materials updated for AS 1163:2016, AS/NZS 3678:2016 and AS 3679.1:2016 standards
		steel material naming convention enhanced to include relevant plate thickness range
		masonry materials added in accordance with NZS 4230:2004
		aluminium material added in accordance with AS/NZS 1664.1:1997
		cold formed steel material properties added in accordance with AS 1397:2001, AS/NZS 1594:2002 and AS/NZS 1595:1998
		common tendon (strand) materials added in accordance with AS/NZS 4671.2:2007
	Version 2.1
		steel materials updated to include AS/NZS3678:2016 Grade 450PL
		cold-formed steel materials for AS/NZS 1594:2002 and AS/NZS 1595:1998 standards renamed from "AS1594..." and "AS1595..." to "AS/NZS1594..." and "AS/NZS1595..." respectively
	Version 2.2
		aluminium material properties corrected (previous versions of the material library erronesouly defined these materials in MPa units)
	Version 2.3
	    Removed materials per Australian standards as well as per standards common to Australia and New Zealand. 
		-->
  </control>
  
  <region name="New Zealand" lengthUnits="m" forceUnits="kN">
  
    <collection type="Materials">
	
	
